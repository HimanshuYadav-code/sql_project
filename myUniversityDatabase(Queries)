-- LAB 11(Transaction Control Management)
-- Start Transaction & COMMIT
start transaction;

update students
set student_name = 'Aman Kumar'
where student_id = 's02';

commit;

-- ROLLBACK
start transaction;

update students
set student_name = 'Wrong Name'
where student_id = 's01';

rollback;

-- SAVEPOINT
start transaction;

update students set student_name = 'Rahul' where student_id = 's01';

savepoint sp1;

update students set student_name = 'Rohit' where student_id = 's01';

rollback to sp1;

commit;

