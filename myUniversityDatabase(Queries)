
-- database create / drop / alter / use
create database myUniversityDatabase;

-- drop database myUniversityDatabase; -- ⚠️ do not run this after putting all the info into the database
-- otherwise you will lose all the data and you need to put datas again.

-- create database myUniversityDatabase;

use myUniversityDatabase;

-- create tables (simple version first)
-- students
create table students(
	student_id varchar(20),
    student_name varchar(50),
    student_dept varchar(50),
    student_dob date,
    student_yearofenrollment varchar(10),
    programid varchar(30)
);
-- altering programid to program_id
alter table students
rename column programid to program_id;

-- program
create table program(
	name varchar(100),
    program_id varchar(30),
    department_id varchar(50)
);
-- department
create table department(
	name varchar(100),
    department_id varchar(50)
);
-- courses
create table courses(
	course_code varchar(20),
    credit int,
    name varchar(100)
);
-- instructors
create table instructors(
	instructor_id varchar(30),
    instructor_name varchar(100),
    sem int,
    hours decimal(5,2),
    department_id varchar(50)
);

-- rename tables
rename table program to programs;
rename table department to departments;

-- adding primary keys
alter table students
add constraint pk_students
primary key(student_id);

alter table programs
add constraint pk_programs
primary key(program_id);

alter table departments
add constraint pk_departments
primary key(department_id);

alter table courses
add constraint pk_courses
primary key(course_code);

alter table instructors
add constraint pk_instructors
primary key(instructor_id);

-- add not null constraints
alter table students
modify student_name varchar(50) not null;

alter table students
modify student_dob date not null;

alter table programs
modify name varchar(100) not null;

alter table departments
modify name varchar(100) not null;

-- add check constraints
alter table instructors
add constraint chk_hours
check(hours <= 40);

alter table courses
add constraint chk_credit
check(credit > 0);

-- alter table students
-- alter student_yearofenrollment
-- set default '2024';

-- add foreign keys
-- students → programs
alter table students
add constraint fk_student_program
foreign key(program_id)
references programs(program_id);
-- programs → departments
alter table programs
add constraint fk_program_department
foreign key(department_id)
references departments(department_id);
-- instructors → departments
alter table instructors
add constraint fk_instructor_department
foreign key(department_id)
references departments(department_id);

-- create junction tables
-- student_course
create table student_course(
	student_id varchar(20),
    course_code varchar(20)
);
-- constraints
alter table student_course
add primary key(student_id, course_code);

-- adding constraints
alter table student_course
add constraint fk_sc_student
foreign key(student_id)
references students(student_id);

alter table student_course
add constraint fk_sc_course
foreign key(course_code)
references courses(course_code);

-- program_course
create table program_course(
	program_id varchar(30),
    course_code varchar(20)
);

-- constraints
alter table program_course
add primary key(program_id, course_code);

alter table program_course
add constraint fk_pc_program
foreign key(program_id)
references programs(program_id);

alter table program_course
add constraint fk_pc_course
foreign key(course_code)
references courses(course_code);

-- instructor_teaches
create table instructor_teaches(
	instructor_id varchar(30),
    course_code varchar(20)
);
-- constraints
alter table instructor_teaches
add primary key(instructor_id, course_code);

alter table instructor_teaches
add constraint fk_it_instructor
foreign key(instructor_id)
references instructors(instructor_id);

alter table instructor_teaches
add constraint fk_it_course
foreign key(course_code)
references courses(course_code);

