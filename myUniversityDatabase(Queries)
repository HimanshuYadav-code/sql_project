-- LAB 7
-- inner join
SELECT s.student_id, s.student_name, p.name AS program_name
FROM students s
INNER JOIN programs p
ON s.program_id = p.program_id;

-- left join
SELECT s.student_id, s.student_name, sc.course_code
FROM students s
LEFT JOIN student_course sc
ON s.student_id = sc.student_id;

-- right join
SELECT sc.course_code, s.student_name
FROM students s
RIGHT JOIN student_course sc
ON s.student_id = sc.student_id;

-- full join
SELECT s.student_id, s.student_name, p.name
FROM students s
LEFT JOIN programs p
ON s.program_id = p.program_id

UNION

SELECT s.student_id, s.student_name, p.name
FROM students s
RIGHT JOIN programs p
ON s.program_id = p.program_id;

-- non-equi join
SELECT i.instructor_name, i.hours, c.name, c.credit
FROM instructors i
JOIN courses c
ON i.hours > c.credit;

